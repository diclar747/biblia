# Variables de entorno para Biblia Online
# Copiar este archivo como .env en desarrollo local
# En Vercel, agregar estas variables en Settings > Environment Variables

# Cadena de conexión a PostgreSQL (Neon)
# Ejemplo: postgresql://usuario:password@host.neon.tech/biblia?sslmode=require
DATABASE_URL=

# Clave secreta para firmar tokens JWT (mínimo 32 caracteres recomendado)
JWT_SECRET=

# Puerto local (opcional, por defecto 3000)
PORT=3000
